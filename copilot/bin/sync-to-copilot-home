#!/bin/bash
set -euo pipefail

SCRIPT_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)"
DOTFILES_ROOT="${DOTFILES_ROOT:-$SCRIPT_ROOT}"
SOURCE_DIR="$DOTFILES_ROOT/copilot"
TARGET_DIR="$HOME/.copilot"

if [[ ! -d "$SOURCE_DIR" ]]; then
  echo "Copilot source directory not found: $SOURCE_DIR"
  exit 1
fi

sync_files() {
  if [[ -d "$SOURCE_DIR/skills" ]]; then
    mkdir -p "$TARGET_DIR/skills"
    cp -R "$SOURCE_DIR/skills/." "$TARGET_DIR/skills/"
  fi

  if [[ -d "$SOURCE_DIR/.github" ]]; then
    mkdir -p "$TARGET_DIR/.github"
    cp -R "$SOURCE_DIR/.github/." "$TARGET_DIR/.github/"
  fi

  echo "Synced Copilot skills and MCP markdown to $TARGET_DIR"
}

if [[ "${1:-}" == "--prompt" ]]; then
  read -r -p "Sync Copilot skills and MCP markdown to $TARGET_DIR? [y/N] " answer
  case "$answer" in
    [Yy]|[Yy][Ee][Ss])
      sync_files
      ;;
    *)
      echo "Skipped Copilot sync."
      ;;
  esac
else
  sync_files
fi
